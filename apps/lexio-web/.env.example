# ---------------------------------------------------------------------------
# Lexio Web — environment variables example
# Copy to .env.local for local development. Never commit real secrets.
# ---------------------------------------------------------------------------

# Prototype flag — set to 'false' to hide the NOT-PROD banner in production
NEXT_PUBLIC_IS_PROTOTYPE=true

# VAPID public key for Web Push notifications.
# Leave EMPTY in this example — an empty value triggers the safe early-exit
# guard in lib/push/subscribe.ts and avoids InvalidAccessError from
# pushManager.subscribe() receiving a non-base64url string.
# To enable push locally: generate a real key pair with:
#   npx web-push generate-vapid-keys
# Server-side push delivery is deferred to the .NET 10 Notification service.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
