# ---------------------------------------------------------------------------
# Lexio Web — environment variables example
# Copy to .env.local for local development. Never commit real secrets.
# ---------------------------------------------------------------------------

# Prototype flag — set to 'false' to hide the NOT-PROD banner in production
NEXT_PUBLIC_IS_PROTOTYPE=true

# VAPID public key for Web Push notifications (stub — not a real key).
# Replace with a real VAPID key pair generated via:
#   npx web-push generate-vapid-keys
# Server-side push delivery is deferred to the .NET 10 Notification service.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=stub-key-not-real
